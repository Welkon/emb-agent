{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/emb-agent/bin/emb-agent.cjs hook session-start --host codex",
            "timeout": 15,
            "statusMessage": "Loading emb-agent context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/emb-agent/bin/emb-agent.cjs hook tool-guard --host codex",
            "timeout": 10,
            "statusMessage": "Checking emb-agent tool policy..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Shell|Exec|exec_command|Edit|Write|MultiEdit|ApplyPatch|apply_patch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/emb-agent/bin/emb-agent.cjs hook context-monitor --host codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
