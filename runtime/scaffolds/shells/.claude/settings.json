{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/emb-agent/bin/emb-agent.cjs hook statusline --host claude"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/emb-agent/bin/emb-agent.cjs hook session-start --host claude",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/emb-agent/bin/emb-agent.cjs hook session-start --host claude",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/emb-agent/bin/emb-agent.cjs hook tool-guard --host claude",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/emb-agent/bin/emb-agent.cjs hook context-monitor --host claude",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
