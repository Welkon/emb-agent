{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/emb-agent/bin/emb-agent.cjs hook session-start --host cursor",
        "timeout": 15
      }
    ],
    "postToolUse": [
      {
        "matcher": "Shell|Write|Edit",
        "command": "node .cursor/emb-agent/bin/emb-agent.cjs hook context-monitor --host cursor",
        "timeout": 10
      }
    ]
  }
}
