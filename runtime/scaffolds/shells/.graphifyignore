# graphify ignore — exclude runtime infrastructure and noise, keep project data.
# Pattern syntax: gitignore-style. Last matching pattern wins.

# ── emb-agent runtime (binaries, command-docs, agents, hooks, profiles, reference, templates, scaffolds, registry) ──
.emb-agent/bin/
.emb-agent/command-docs/
.emb-agent/agents/
.emb-agent/hooks/
.emb-agent/profiles/
.emb-agent/reference/
.emb-agent/templates/
.emb-agent/scaffolds/
.emb-agent/registry/
.emb-agent/config.json
.emb-agent/HOST.json
.emb-agent/VERSION
.emb-agent/state/
.emb-agent/backups/

# ── emb-agent cache noise (images, mineru metadata, ingest state) ──
.emb-agent/cache/docs/**/images/
.emb-agent/cache/docs/**/*.json
.emb-agent/cache/schematics/**/images/
.emb-agent/cache/

# ── emb-agent project data — KEEP (un-exclude after blanket exclude) ──
.emb-agent/
!.emb-agent/cache/docs/*.md
!.emb-agent/cache/schematics/**/parsed.json
!.emb-agent/cache/schematics/**/analysis.*.json
!.emb-agent/req.yaml
!.emb-agent/hw.yaml
!.emb-agent/tasks/
!.emb-agent/compound/
!.emb-agent/wiki/
!.emb-agent/memory/
!.emb-agent/specs/

# ── host tooling ──
.codex/
.claude/
.cursor/
.omp/
.agents/

# ── tool artifacts ──
backup/
graphify-out/

# ── already converted to .md by markitdown ──
*.pdf
*.PDF

# ── build outputs ──
*.o
*.hex
*.elf
*.bin
*.map
build/
dist/
obj/

# ── IDE and OS noise ──
.vscode/
.idea/
.DS_Store
Thumbs.db
