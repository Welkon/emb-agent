{
  "name": "emb-agent",
  "version": "0.5.0",
  "description": "A lightweight embedded workflow system for Codex, Cursor, Claude, Pi and other AI runtimes, optimized for MCU, RTOS, and IoT repositories.",
  "bin": {
    "emb-agent": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "command-docs",
    "agents",
    "runtime",
    "scripts"
  ],
  "keywords": [
    "embedded",
    "firmware",
    "rtos",
    "iot",
    "installer",
    "multi-runtime"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Welkon/emb-agent"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "test": "cargo test --workspace",
    "build": "cargo build --release",
    "release:check": "cargo build --release && cargo test --workspace"
  }
}
