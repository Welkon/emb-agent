{
  "name": "emb-agent",
  "version": "0.3.0",
  "description": "A lightweight embedded workflow system for Codex and other AI runtimes, optimized for MCU, RTOS, and IoT repositories.",
  "bin": {
    "emb-agent": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "agents",
    "runtime/bin",
    "runtime/chips",
    "runtime/config.json",
    "runtime/hooks",
    "runtime/lib",
    "runtime/registry",
    "runtime/scaffolds",
    "runtime/schemas",
    "runtime/profiles",
    "runtime/README.md",
    "runtime/scripts",
    "runtime/state/default-session.json",
    "runtime/templates",
    "runtime/tools",
    "scripts"
  ],
  "keywords": [
    "embedded",
    "firmware",
    "rtos",
    "iot",
    "installer",
    "multi-runtime"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node scripts/run-tests.cjs",
    "test:behavior": "node scripts/behavior-drift-check.cjs",
    "test:ci": "npm test && npm run test:behavior",
    "bench:brief": "node benchmarks/brief-benchmark.cjs",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "node scripts/release-check.cjs"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "giget": "^3.2.0",
    "ora": "^5.4.1"
  }
}
